# Server
LISTEN_ADDR=:8080
BASE_URL=http://localhost:8080

# Database (leave as default unless you have a reason to change)
DB_PATH=/data/dsforms.db

# Auth
# SECRET_KEY is used to sign flash cookies. Generate with:
#   openssl rand -base64 32
SECRET_KEY=change-me-to-a-random-32-char-string

# SMTP — sends email notifications when forms are submitted
#
# Development: Mailpit is included in docker-compose (no auth needed)
# View emails at http://localhost:8025
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DSForms <noreply@example.com>
#
# Production examples (uncomment one):
#
# Gmail (use App Password: https://myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=DSForms <you@gmail.com>
#
# Resend (free 3k emails/month: https://resend.com)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key
# SMTP_FROM=DSForms <noreply@yourdomain.com>
#
# Brevo (free 300/day: https://brevo.com)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-smtp-key

# Rate limiting (applied to POST /f/{formID} only)
RATE_BURST=5
RATE_PER_MINUTE=6

# Backup (CLI only — optional)
# If set, "docker compose exec dsforms ./dsforms backup create" writes a
# snapshot here. Leave unset if you don't need CLI-triggered backups.
# UI export/import works regardless of this setting.
#BACKUP_LOCAL_DIR=/data/backups
